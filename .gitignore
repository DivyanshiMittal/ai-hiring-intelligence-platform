# =============================================================================
# Hiring-Copilot — .gitignore
# Covers: Next.js, FastAPI, Python, Docker, macOS, VS Code
# =============================================================================

# -----------------------------------------------------------------------------
# Secrets & environment
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
*.local
secrets/
*.pem
*.key

# -----------------------------------------------------------------------------
# Node / Next.js (apps/web)
# -----------------------------------------------------------------------------
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Next.js build output
.next/
out/
build/
dist/
.swc/

# Production / misc
.vercel
*.tsbuildinfo
next-env.d.ts

# Package manager logs & caches
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.npm
.eslintcache
.turbo

# Testing
coverage/
.nyc_output/
/playwright-report/
/test-results/
/blob-report/
/playwright/.cache/

# -----------------------------------------------------------------------------
# Python / FastAPI (apps/api)
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
.Python
develop-eggs/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/
.python-version

# Tooling caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/
.cache
.hypothesis/

# Coverage
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover
*.py,cover
nosetests.xml

# Jupyter
.ipynb_checkpoints/

# FastAPI / app runtime artifacts
*.log
logs/
uploads/
media/
local_storage/
instance/

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
# Local compose overrides (keep the committed base compose file)
docker-compose.override.yml
*.override.yml

# Local bind-mounted data volumes
.docker/
data/
volumes/
pgdata/
qdrant_storage/
minio_data/
redis_data/

# -----------------------------------------------------------------------------
# macOS
# -----------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk

# -----------------------------------------------------------------------------
# VS Code
# -----------------------------------------------------------------------------
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/*.code-snippets
.history/
*.code-workspace

# -----------------------------------------------------------------------------
# Misc IDE / OS / editor
# -----------------------------------------------------------------------------
.idea/
*.swp
*.swo
*~
Thumbs.db
